/**
 * WC2026 — Firestore Security Rules (PRODUCCIÓN)
 *
 * Lectura pública para el sitio web (cualquiera puede ver).
 * Escritura solo para usuarios autenticados (admin panel).
 *
 * CÓMO DEPLOYAR:
 *   1. Ir a Firebase Console → Firestore Database → Rules
 *   2. Pegar estas reglas
 *   3. Click "Publish"
 *
 * CONFIGURACIÓN DE AUTH:
 *   1. Firebase Console → Authentication → Get Started
 *   2. Enable "Email/Password" provider
 *   3. Agregar un usuario en "Users"
 *   4. Usar ese email/password en admin-seed.html
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Partidos fase de grupos — lectura pública, escritura solo auth
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Partidos eliminatorias — lectura pública, escritura solo auth
    match /knockout/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Goleadores — lectura pública, escritura solo auth
    match /scorers/{scorerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Tarjetas — lectura pública, escritura solo auth
    match /cards/{cardId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Denegar todo lo demás
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
