/**
 * WC2026 — Firestore Security Rules
 *
 * These rules allow:
 *   - PUBLIC READ: Anyone can view match results, standings, and stats
 *   - AUTHENTICATED WRITE: Only signed-in admin users can modify data
 *
 * HOW TO DEPLOY:
 *   1. Install Firebase CLI: npm install -g firebase-tools
 *   2. Login: firebase login
 *   3. Init: firebase init firestore (select existing project)
 *   4. Copy this file to firestore.rules in your project root
 *   5. Deploy: firebase deploy --only firestore:rules
 *
 * ALTERNATIVE (Firebase Console):
 *   1. Go to Firestore Database → Rules tab
 *   2. Paste the rules below
 *   3. Click "Publish"
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Matches collection — public read, authenticated write
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Scorers collection — public read, authenticated write
    match /scorers/{scorerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Cards collection — public read, authenticated write
    match /cards/{cardId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny all other collections
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
